# Ligen Astralogie — Variables d'environnement
# Copier en .env et adapter : cp .env.example .env
# Ne jamais committer .env en production

# ── Flask ─────────────────────────────────────────────────────────────────────
FLASK_ENV=development           # development | production | testing
LIGEN_SECRET_KEY=change-me-in-production

# ── Base de données SQLite ────────────────────────────────────────────────────
LIGEN_DB_PATH=ligen.db          # Chemin relatif ou absolu
                                 # Ex. production : /data/ligen.db

# ── Éphémérides Swiss Ephemeris ───────────────────────────────────────────────
# Dossier contenant seas_18.se1 + fichiers astéroïdes
LIGEN_EPHE_PATH=/home/user/ephe  # Windows : C:\swisseph\ephe
SE_EPHE_PATH=/home/user/ephe     # Alias pour tests pytest

# ── Rapports PDF ──────────────────────────────────────────────────────────────
LIGEN_REPORTS_DIR=reports        # Dossier de sortie des PDF générés

# ── Prompts et templates ──────────────────────────────────────────────────────
LIGEN_PROMPTS_DIR=ligen/prompts/blocks
LIGEN_TEMPLATES_DIR=ligen/reports/templates

# ── Serveur Gunicorn (production) ─────────────────────────────────────────────
# gunicorn "ligen.api.app:create_app()" -b 0.0.0.0:5000 -w 2
GUNICORN_WORKERS=2
GUNICORN_BIND=0.0.0.0:5000
GUNICORN_TIMEOUT=120

# ── CORS (si frontend séparé) ─────────────────────────────────────────────────
# LIGEN_CORS_ORIGINS=http://localhost:3000,https://ton-domaine.com
